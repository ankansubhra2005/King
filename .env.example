# KING — Environment Configuration Template
# Copy this file to .env and fill in your keys

# External APIs (Recon Mode)
SHODAN_API_KEY=your_shodan_api_key
CENSYS_API_ID=your_censys_api_id
CENSYS_API_SECRET=your_censys_api_secret
GITHUB_TOKEN=your_github_personal_access_token
SECURITY_TRAILS_API_KEY=your_securitytrails_key
SERP_API_KEY=your_serpapi_key_for_google_dorks

# AI Triage & Reporting
OPENAI_API_KEY=your_openai_key

# Vulnerability Scanning
BLIND_XSS_CALLBACK_URL=https://your-callback.burpcollaborator.net
OOB_SERVER_URL=https://your-oob-server.com

# Notifications
SLACK_WEBHOOK_URL=your_slack_webhook
DISCORD_WEBHOOK_URL=your_discord_webhook
TELEGRAM_BOT_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Database (Optional for persistence)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/recon_db
REDIS_URL=redis://localhost:6379/0
